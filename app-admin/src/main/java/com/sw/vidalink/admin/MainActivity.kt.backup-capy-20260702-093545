private data class Telemetry(
    val deviceId: String = "",
    val displayName: String = "Acompanhado",
    val lat: Double? = null,
    val lng: Double? = null,
    val accuracy: Double? = null,
    val batteryPct: Int? = null,
    val sos: Boolean = false,
    val ts: Long? = null,
    val message: String = ""
)

