@Composable
private fun DashboardCard(
    status: String,
    telemetry: Telemetry?,
    onRefresh: () -> Unit,
    autoRefresh: Boolean,
    onToggleLive: () -> Unit
) {
    val context = LocalContext.current
    ElevatedCard(shape = RoundedCornerShape(28.dp), colors = CardDefaults.elevatedCardColors(containerColor = Color.White)) {
        Column(Modifier.padding(18.dp), verticalArrangement = Arrangement.spacedBy(10.dp)) {
            Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                Text("Painel da família", style = MaterialTheme.typography.titleLarge, fontWeight = FontWeight.Bold)
                AssistChip(onClick = {}, label = { Text(if (telemetry?.ts != null) "Conectado" else "Aguardando") })
            }
            Text(status)
            Spacer(Modifier.height(4.dp))
            InfoLine("Nome", telemetry?.displayName ?: "—")
            InfoLine("Bateria", telemetry?.batteryPct?.let { "$it%" } ?: "—")
            InfoLine("Precisão GPS", telemetry?.accuracy?.let { "%.1f m".format(it) } ?: "—")
            InfoLine("Último horário", telemetry?.ts?.let { formatTime(it) } ?: "—")
            InfoLine("Mensagem", telemetry?.message?.ifBlank { "—" } ?: "—")

            if (telemetry?.sos == true) {
                OutlinedCard(colors = CardDefaults.outlinedCardColors(containerColor = Color(0xFFFFE4E6))) {
                    Text("SOS ATIVO", color = Color(0xFFB91C1C), fontWeight = FontWeight.Black, modifier = Modifier.padding(14.dp))
                }
            }

            if (telemetry?.lat != null && telemetry.lng != null) {
                InfoLine("Latitude", telemetry.lat.toString())
                InfoLine("Longitude", telemetry.lng.toString())
                Button(onClick = {
                    val uri = Uri.parse("geo:${telemetry.lat},${telemetry.lng}?q=${telemetry.lat},${telemetry.lng}(Bem-estar)")
                    context.startActivity(Intent(Intent.ACTION_VIEW, uri))
                }) { Text("Abrir no mapa") }
            }

            Row(horizontalArrangement = Arrangement.spacedBy(10.dp)) {
                FilledTonalButton(onClick = onRefresh) { Text("Atualizar") }
                TextButton(onClick = onToggleLive) { Text(if (autoRefresh) "Pausar ao vivo" else "Ativar ao vivo") }
            }
        }
    }
}

