    }
}

@Composable
private fun AdminApp() {
    val context = LocalContext.current
    val prefs = remember { context.getSharedPreferences("vidalink_admin", Context.MODE_PRIVATE) }
    var backendUrl by remember { mutableStateOf(prefs.getString("backendUrl", "") ?: "") }
    var familyCode by remember { mutableStateOf(prefs.getString("familyCode", "") ?: "") }
    var generatedCode by remember { mutableStateOf(familyCode) }
    var status by remember { mutableStateOf(if (familyCode.isBlank()) "Crie um código para conectar o app Bem-estar." else "Código familiar ativo: $familyCode") }
    var telemetry by remember { mutableStateOf<Telemetry?>(null) }
    var autoRefresh by remember { mutableStateOf(false) }
    var showAdvanced by remember { mutableStateOf(backendUrl.isBlank()) }
    val scope = rememberCoroutineScope()

    LaunchedEffect(autoRefresh, backendUrl, familyCode) {
        while (autoRefresh) {
            telemetry = Repository.readLatest(backendUrl, familyCode)
            status = if (telemetry?.lat != null) "Capy encontrou uma atualização recente." else "Aguardando o Bem-estar enviar dados."
            delay(5000)
        }
    }

    CapyTheme {
        Surface(
            modifier = Modifier.fillMaxSize(),
            color = MaterialTheme.colorScheme.background
        ) {
            Column(
                modifier = Modifier
                    .fillMaxSize()
                    .background(Brush.verticalGradient(listOf(Color(0xFFEAF7F0), Color(0xFFFFFFFF))))
                    .verticalScroll(rememberScrollState())
                    .padding(18.dp),
                verticalArrangement = Arrangement.spacedBy(16.dp)
            ) {
                HeaderCard(
                    title = "Família+",
                    subtitle = "Cuidado familiar com a Capy: localização consentida, rotina e SOS.",
                    chip = "App do responsável"
                )

                ElevatedCard(
                    shape = RoundedCornerShape(28.dp),
                    colors = CardDefaults.elevatedCardColors(containerColor = Color.White)
                ) {
                    Column(Modifier.padding(18.dp), verticalArrangement = Arrangement.spacedBy(14.dp)) {
                        Text("Adicionar acompanhado", style = MaterialTheme.typography.titleLarge, fontWeight = FontWeight.Bold)
                        Text("Gere um código no Família+ e digite esse código no app Bem-estar.")

                        if (generatedCode.isNotBlank()) {
                            OutlinedCard(shape = RoundedCornerShape(22.dp), modifier = Modifier.fillMaxWidth()) {
                                Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(6.dp)) {
                                    Text("Código de conexão", color = Color(0xFF52605A))
                                    Text(generatedCode, style = MaterialTheme.typography.headlineMedium, fontWeight = FontWeight.Black, color = Color(0xFF2F6B4F))
                                    Text("Digite este código no app Bem-estar.")
                                }
                            }
                        }

                        Row(horizontalArrangement = Arrangement.spacedBy(10.dp), modifier = Modifier.fillMaxWidth()) {
                            Button(onClick = {
                                scope.launch {
                                    val cleanBackend = backendUrl.trim()
                                    if (cleanBackend.isBlank()) {
                                        showAdvanced = true
                                        status = "Configure o servidor uma vez para gerar códigos."
                                        return@launch
                                    }
                                    val code = generatePairingCode()
                                    val ok = Repository.createPairingCode(cleanBackend, code)
                                    if (ok) {
                                        generatedCode = code
                                        familyCode = code
                                        prefs.edit()
                                            .putString("backendUrl", cleanBackend)
                                            .putString("familyCode", code)
                                            .apply()
                                        autoRefresh = true
                                        status = "Código $code criado. Agora abra o Bem-estar no outro aparelho."
                                    } else {
                                        status = "Não consegui criar o código. Verifique a URL e as regras do Firebase."
                                    }
                                }
                            }) { Text("Gerar código") }

                            FilledTonalButton(onClick = {
                                val text = if (generatedCode.isBlank()) {
                                    "Abra o Família+ e gere um código para conectar o Bem-estar."
                                } else {
                                    "Código Família+: $generatedCode\nDigite este código no app Bem-estar."
                                }
                                context.startActivity(Intent.createChooser(Intent(Intent.ACTION_SEND).apply {
                                    type = "text/plain"
                                    putExtra(Intent.EXTRA_TEXT, text)
                                }, "Compartilhar código"))
                            }) { Text("Compartilhar") }
                        }

                        TextButton(onClick = { showAdvanced = !showAdvanced }) {
                            Text(if (showAdvanced) "Ocultar configuração avançada" else "Configuração avançada")
                        }

                        if (showAdvanced) {
                            OutlinedTextField(
                                value = backendUrl,
                                onValueChange = { backendUrl = it },
                                label = { Text("URL do Firebase Realtime Database") },
                                placeholder = { Text("https://seu-projeto-default-rtdb.firebaseio.com") },
                                modifier = Modifier.fillMaxWidth(),
                                singleLine = true
                            )
                            FilledTonalButton(onClick = {
                                prefs.edit().putString("backendUrl", backendUrl.trim()).putString("familyCode", familyCode.trim()).apply()
                                status = "Configuração salva."
                            }) { Text("Salvar servidor") }
                        }
                    }
                }

                DashboardCard(status, telemetry, onRefresh = {
                    scope.launch {
                        telemetry = Repository.readLatest(backendUrl, familyCode)
                        status = if (telemetry?.lat != null) "Dados carregados." else "Ainda não há telemetria neste código."
                    }
                }, autoRefresh = autoRefresh, onToggleLive = { autoRefresh = !autoRefresh })

                OutlinedCard(shape = RoundedCornerShape(24.dp), modifier = Modifier.fillMaxWidth()) {
                    Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Text("Próximos blocos", style = MaterialTheme.typography.titleMedium, fontWeight = FontWeight.Bold)
                        Text("Depois desta base: locais seguros, histórico de rotas, alerta escola/casa e plano premium.")
                    }
                }
            }
        }
    }
}

