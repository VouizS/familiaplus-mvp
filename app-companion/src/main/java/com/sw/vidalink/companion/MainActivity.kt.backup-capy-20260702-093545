    Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
        Text(label, color = Color(0xFF52605A))
        Text(value, fontWeight = FontWeight.SemiBold)
    }
}

@Composable
private fun CapyTheme(content: @Composable () -> Unit) {
    val colors = lightColorScheme(
        primary = Color(0xFF2F6B4F),
        secondary = Color(0xFF6D5BD0),
        tertiary = Color(0xFF0EA5A4),
        background = Color(0xFFF7FBF8),
        surface = Color.White,
        error = Color(0xFFB91C1C)
    )
    MaterialTheme(colorScheme = colors, content = content)
}

private object Repository {
    suspend fun validatePairingCode(baseUrl: String, code: String): String? = withContext(Dispatchers.IO) {
        val cleanBase = baseUrl.trim().removeSuffix("/")
        if (cleanBase.isBlank() || code.isBlank()) return@withContext null
        val raw = httpGet("$cleanBase/pairingCodes/${enc(code)}.json") ?: return@withContext null
        if (raw == "null") return@withContext null
        val obj = runCatching { JSONObject(raw) }.getOrNull() ?: return@withContext null
        if (!obj.optBoolean("active", false)) return@withContext null
        obj.optString("familyCode", code).ifBlank { code }
    }

    private fun httpGet(urlText: String): String? {
        val conn = (URL(urlText).openConnection() as HttpURLConnection).apply {
            requestMethod = "GET"
            connectTimeout = 10000
            readTimeout = 10000
        }
        return try {
            conn.inputStream.bufferedReader().use { it.readText() }
        } catch (_: Exception) {
            null
        } finally {
            conn.disconnect()
        }
    }

    private fun enc(value: String): String = URLEncoder.encode(value, "UTF-8")
}

