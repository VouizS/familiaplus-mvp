    }
}

@Composable
private fun CompanionApp() {
    val context = LocalContext.current
    val prefs = remember { context.getSharedPreferences("vidalink_companion", Context.MODE_PRIVATE) }
    var backendUrl by remember { mutableStateOf(prefs.getString("backendUrl", "") ?: "") }
    var pairingCode by remember { mutableStateOf(prefs.getString("familyCode", "") ?: "") }
    var displayName by remember { mutableStateOf(prefs.getString("displayName", "Acompanhado") ?: "Acompanhado") }
    var connected by remember { mutableStateOf(prefs.getBoolean("connected", false)) }
    var showAdvanced by remember { mutableStateOf(backendUrl.isBlank()) }
    var status by remember {
        mutableStateOf(
            when {
                !connected -> "Digite o código que aparece no app Família+."
                hasLocationPermission(context) -> "Proteção ativa. A Capy está acompanhando sua rotina com transparência."
                else -> "Conectado. Agora permita a localização para ativar a proteção."
            }
        )
    }
    val scope = rememberCoroutineScope()

    val locationPermissionLauncher = rememberLauncherForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { permissions ->
        val granted = permissions[Manifest.permission.ACCESS_FINE_LOCATION] == true || permissions[Manifest.permission.ACCESS_COARSE_LOCATION] == true
        status = if (granted) {
            if (connected) {
                LocationShareService.start(context)
                "Localização permitida. Proteção ativa com notificação visível."
            } else {
                "Permissão concedida. Agora conecte usando o código da família."
            }
        } else {
            "Permissão negada. O app não pode compartilhar localização."
        }
    }

    CapyTheme {
        Surface(modifier = Modifier.fillMaxSize(), color = MaterialTheme.colorScheme.background) {
            Column(
                modifier = Modifier
                    .fillMaxSize()
                    .background(Brush.verticalGradient(listOf(Color(0xFFEFFAF5), Color(0xFFFFFFFF))))
                    .verticalScroll(rememberScrollState())
                    .padding(18.dp),
                verticalArrangement = Arrangement.spacedBy(16.dp)
            ) {
                HeaderCard(
                    title = "Bem-estar",
                    subtitle = "Conecte este aparelho ao Família+ usando o código do responsável.",
                    chip = if (connected) "Conectado" else "Aguardando código"
                )

                if (!connected) {
                    ElevatedCard(shape = RoundedCornerShape(28.dp), colors = CardDefaults.elevatedCardColors(containerColor = Color.White)) {
                        Column(Modifier.padding(18.dp), verticalArrangement = Arrangement.spacedBy(14.dp)) {
                            Text("Conectar com minha família", style = MaterialTheme.typography.titleLarge, fontWeight = FontWeight.Bold)
                            Text("Peça o código no app Família+. Ele tem 6 caracteres.")

                            OutlinedTextField(
                                value = pairingCode,
                                onValueChange = { pairingCode = it.uppercase().take(6) },
                                label = { Text("Código da família") },
                                placeholder = { Text("A7K29P") },
                                modifier = Modifier.fillMaxWidth(),
                                singleLine = true
                            )
                            OutlinedTextField(
                                value = displayName,
                                onValueChange = { displayName = it },
                                label = { Text("Nome exibido") },
                                modifier = Modifier.fillMaxWidth(),
                                singleLine = true
                            )

                            Text(status)

                            Row(horizontalArrangement = Arrangement.spacedBy(10.dp), modifier = Modifier.fillMaxWidth()) {
                                FilledTonalButton(onClick = { requestLocation(locationPermissionLauncher) }) { Text("Permitir localização") }
                                Button(onClick = {
                                    scope.launch {
                                        val cleanBackend = backendUrl.trim()
                                        val cleanCode = pairingCode.trim().uppercase()
                                        if (cleanBackend.isBlank()) {
                                            showAdvanced = true
                                            status = "Configure o servidor uma vez antes de conectar."
                                            return@launch
                                        }
                                        if (cleanCode.length < 6) {
                                            status = "Digite o código completo de 6 caracteres."
                                            return@launch
                                        }
                                        val familyCode = Repository.validatePairingCode(cleanBackend, cleanCode)
                                        if (familyCode == null) {
                                            status = "Código não encontrado. Confira no app Família+."
                                            return@launch
                                        }
                                        prefs.edit()
                                            .putString("backendUrl", cleanBackend)
                                            .putString("familyCode", familyCode)
                                            .putString("displayName", displayName.trim().ifBlank { "Acompanhado" })
                                            .putBoolean("connected", true)
                                            .apply()
                                        connected = true
                                        pairingCode = familyCode
                                        if (hasLocationPermission(context)) {
                                            LocationShareService.start(context)
                                            status = "Conectado. Proteção ativa com notificação visível."
                                        } else {
                                            status = "Conectado. Agora permita a localização para iniciar."
                                        }
                                    }
                                }) { Text("Conectar") }
                            }

                            TextButton(onClick = { showAdvanced = !showAdvanced }) {
                                Text(if (showAdvanced) "Ocultar configuração avançada" else "Configuração avançada")
                            }

                            if (showAdvanced) {
                                OutlinedTextField(
                                    value = backendUrl,
                                    onValueChange = { backendUrl = it },
                                    label = { Text("URL do Firebase Realtime Database") },
                                    placeholder = { Text("https://seu-projeto-default-rtdb.firebaseio.com") },
                                    modifier = Modifier.fillMaxWidth(),
                                    singleLine = true
                                )
                                FilledTonalButton(onClick = {
                                    prefs.edit().putString("backendUrl", backendUrl.trim()).apply()
                                    status = "Servidor salvo. Agora conecte com o código."
                                }) { Text("Salvar servidor") }
                            }
                        }
                    }
                } else {
                    ActiveProtectionCard(
                        status = status,
                        displayName = displayName,
                        pairingCode = pairingCode,
                        onRequestPermission = { requestLocation(locationPermissionLauncher) },
                        onStart = {
                            if (hasLocationPermission(context)) {
                                LocationShareService.start(context)
                                status = "Proteção ativa. Uma notificação fixa mostra o compartilhamento."
                            } else {
                                status = "Permita a localização primeiro."
                            }
                        },
                        onSos = {
                            LocationShareService.sendSos(context)
                            status = "SOS enviado com a última localização disponível."
                        },
                        onPause = {
                            LocationShareService.stop(context)
                            status = "Compartilhamento pausado. Você pode ativar novamente quando quiser."
                        },
                        onDisconnect = {
                            LocationShareService.stop(context)
                            prefs.edit().putBoolean("connected", false).apply()
                            connected = false
                            status = "Digite o código que aparece no app Família+."
                        }
                    )
                }

                OutlinedCard(shape = RoundedCornerShape(24.dp), modifier = Modifier.fillMaxWidth()) {
                    Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Text("Transparência", style = MaterialTheme.typography.titleLarge, fontWeight = FontWeight.Bold)
                        Text("O Bem-estar é visível. O compartilhamento usa permissão concedida e notificação ativa.")
                        Text("Sem modo escondido. Sem gravação oculta. O controle de pausa fica disponível no aparelho acompanhado.")
                    }
                }
            }
        }
    }
}

private fun requestLocation(launcher: androidx.activity.result.ActivityResultLauncher<Array<String>>) {
    val permissions = buildList {
        add(Manifest.permission.ACCESS_FINE_LOCATION)
        add(Manifest.permission.ACCESS_COARSE_LOCATION)
        if (Build.VERSION.SDK_INT >= 33) add(Manifest.permission.POST_NOTIFICATIONS)
    }.toTypedArray()
    launcher.launch(permissions)
}

